snippet binpow "binary exponentiation"
${1:type} binpow($1 a, $1 b, $1 mod = -1) {
    long long res = 1;

    while (b > 0) {
        if (b & 1) {
            res = res * a;
            if (mod != -1) res %= mod;
        }
        a = a * a;
        if (mod != -1) a %= mod;

        b >>= 1;
    }

    return res;
}
endsnippet
